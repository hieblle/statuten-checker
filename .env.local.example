# ----------------------------------------------------------------------------
# Kopiere diese Datei nach ".env.local" und trage deinen OpenAI-API-Key ein.
# Den Key bekommst du unter https://platform.openai.com/  ->  API Keys
# Die Datei .env.local wird NICHT eingecheckt (siehe .gitignore).
# ----------------------------------------------------------------------------

OPENAI_API_KEY=sk-...

# Modell für die inhaltliche Prüfung.
#   gpt-4.1     = starke Qualität, Structured Outputs (Standard)
#   gpt-4.1-mini / gpt-4o-mini = deutlich günstiger, für hohes Volumen
# Optional – wenn nicht gesetzt, wird gpt-4.1 verwendet.
OPENAI_MODEL=gpt-4.1

# Optionaler Schutz: wenn gesetzt, muss jeder Request den Header
# "x-app-token" mit genau diesem Wert mitschicken (einfacher Zugriffsschutz
# beim Deployen). Lokal kannst du das leer lassen.
# APP_ACCESS_TOKEN=
